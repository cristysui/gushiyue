# 图片资源：1年长缓存（文件名不变则内容不变）
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Next.js 静态资源：1年长缓存（带 hash 文件名）
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Service Worker：不缓存（保证更新及时）
/sw.js
  Cache-Control: no-cache

# HTML 页面：短缓存 + 必须验证
/*
  Cache-Control: public, max-age=0, must-revalidate
