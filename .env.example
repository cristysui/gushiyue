# ===== 外部 API 配置（可选）=====
# 聚合数据 Key（用于获取真实黄历/节气数据）
# 申请地址：https://www.juhe.cn/
JUHE_KEY=

# 天行数据 Key（备用节气 API）
# 申请地址：https://www.tianapi.com/
TIANAPI_KEY=

# ===== AI 模型配置（可选，不配置则使用模拟回复）=====
# 支持 OpenAI 兼容接口的大模型（DeepSeek、豆包等）
# DeepSeek 申请地址：https://platform.deepseek.com/
AI_API_KEY=
AI_API_URL=https://api.deepseek.com/v1/chat/completions
AI_MODEL=deepseek-chat

# ===== Supabase 配置（可选，用于用户数据持久化）=====
# 申请地址：https://supabase.com/
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
